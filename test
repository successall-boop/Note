<%@ Page Language="C#" AutoEventWireup="true" CodeBehind="Default.aspx.cs" Inherits="WebFormsUniverDemo.Default" %>

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head runat="server">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Univer Sheets Web Forms Demo</title>

    <link rel="stylesheet" href="https://unpkg.com/@univerjs/design@0.20.1/lib/index.css" />
    <link rel="stylesheet" href="https://unpkg.com/@univerjs/ui@0.20.1/lib/index.css" />
    <link rel="stylesheet" href="https://unpkg.com/@univerjs/docs-ui@0.20.1/lib/index.css" />
    <link rel="stylesheet" href="https://unpkg.com/@univerjs/sheets-ui@0.20.1/lib/index.css" />
    <link rel="stylesheet" href="https://unpkg.com/@univerjs/sheets-formula-ui@0.20.1/lib/index.css" />
    <link rel="stylesheet" href="https://unpkg.com/@univerjs/sheets-numfmt-ui@0.20.1/lib/index.css" />

    <style>
        html, body, form, #app {
            margin: 0;
            width: 100%;
            height: 100%;
        }

        .page {
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .toolbar {
            padding: 12px 16px;
            border-bottom: 1px solid #ddd;
            background: #f7f7f7;
        }

        .sheet-wrap {
            flex: 1;
            min-height: 0;
        }

        #saveStatus {
            margin-left: 12px;
        }
    </style>
</head>
<body>
    <form id="form1" runat="server">
        <div class="page">
            <div class="toolbar">
                <button type="button" id="btnSave">儲存</button>
                <span id="saveStatus">尚未儲存</span>
            </div>
            <div class="sheet-wrap">
                <div id="app"></div>
            </div>
        </div>

        <asp:HiddenField ID="hfWorkbookJson" runat="server" />

        <script src="https://unpkg.com/@univerjs/presets@0.20.1/lib/umd/index.js"></script>
        <script src="https://unpkg.com/@univerjs/preset-sheets-core@0.20.1/lib/umd/index.js"></script>
        <script src="https://unpkg.com/@univerjs/preset-sheets-core@0.20.1/lib/umd/locales/zh-CN.js"></script>
        <script src="https://unpkg.com/@univerjs/core@0.20.1/lib/umd/facade.js"></script>
        <script src="https://unpkg.com/@univerjs/sheets@0.20.1/lib/umd/facade.js"></script>
        <script src="https://unpkg.com/@univerjs/sheets-ui@0.20.1/lib/umd/facade.js"></script>

        <script>
            (function () {
                var hiddenField = document.getElementById('<%= hfWorkbookJson.ClientID %>');
                var saveButton = document.getElementById('btnSave');
                var saveStatus = document.getElementById('saveStatus');
                var initialWorkbook = JSON.parse(hiddenField.value);

                var createUniver = UniverPresets.createUniver;
                var LocaleType = UniverCore.LocaleType;
                var mergeLocales = UniverCore.mergeLocales;
                var FUniver = UniverCoreFacade.FUniver;
                var UniverSheetsCorePreset = UniverPresetSheetsCore.UniverSheetsCorePreset;
                var zhCN = UniverPresetSheetsCoreZhCN;

                var result = createUniver({
                    locale: LocaleType.ZH_CN,
                    locales: (function () {
                        var locales = {};
                        locales[LocaleType.ZH_CN] = mergeLocales(zhCN);
                        return locales;
                    })(),
                    presets: [
                        UniverSheetsCorePreset({
                            container: 'app'
                        })
                    ]
                });

                var univer = result.univer;
                var univerAPI = FUniver.newAPI(univer);

                univerAPI.createWorkbook(initialWorkbook);

                saveButton.addEventListener('click', async function () {
                    try {
                        saveButton.disabled = true;
                        saveStatus.textContent = '儲存中...';

                        var workbook = univerAPI.getActiveWorkbook();
                        await workbook.endEditingAsync(true);

                        var snapshot = workbook.save();

                        var response = await fetch('Default.aspx/SaveWorkbook', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json; charset=utf-8'
                            },
                            body: JSON.stringify({
                                workbookJson: JSON.stringify(snapshot)
                            })
                        });

                        var result = await response.json();

                        if (!result.d || !result.d.success) {
                            throw new Error((result.d && result.d.message) || '儲存失敗');
                        }

                        saveStatus.textContent = result.d.message;
                    } catch (err) {
                        saveStatus.textContent = '儲存失敗：' + err.message;
                    } finally {
                        saveButton.disabled = false;
                    }
                });
            })();
        </script>
    </form>
</body>
</html>
