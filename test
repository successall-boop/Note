<%@ Page Language="C#" AutoEventWireup="true" CodeBehind="Default.aspx.cs" Inherits="WebFormsUniverDemo.Default" %>

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head runat="server">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Univer Sheets Web Forms Demo</title>

    <link rel="stylesheet" href="https://esm.sh/@univerjs/preset-sheets-core@0.20.1/lib/index.css" />

    <style>
        html, body, form {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            font-family: Arial, sans-serif;
        }

        .page {
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .toolbar {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-bottom: 1px solid #ddd;
            background: #f7f7f7;
        }

        .toolbar button {
            padding: 8px 14px;
            border: 1px solid #bbb;
            background: #fff;
            cursor: pointer;
        }

        .toolbar button:hover {
            background: #f0f0f0;
        }

        .status {
            font-size: 14px;
            color: #444;
        }

        .sheet-wrap {
            flex: 1;
            min-height: 0;
        }

        #app {
            width: 100%;
            height: 100%;
        }
    </style>
</head>
<body>
    <form id="form1" runat="server">
        <div class="page">
            <div class="toolbar">
                <button type="button" id="btnSave">儲存</button>
                <span id="saveStatus" class="status">尚未儲存</span>
            </div>

            <div class="sheet-wrap">
                <div id="app"></div>
            </div>
        </div>

        <asp:HiddenField ID="hfWorkbookJson" runat="server" />

        <script>
            window.saveUrl = 'Default.aspx/SaveWorkbook';
        </script>
        <script type="module" src="Scripts/univer-page.js"></script>
    </form>
</body>
</html>
