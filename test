using System;
using System.Collections.Generic;
using System.IO;
using System.Text;
using System.Web;
using System.Web.Script.Serialization;
using System.Web.Services;

namespace WebFormsUniverDemo
{
    public partial class Default : System.Web.UI.Page
    {
        protected void Page_Load(object sender, EventArgs e)
        {
            if (!IsPostBack)
            {
                hfWorkbookJson.Value = LoadWorkbookJson();
            }
        }

        private string LoadWorkbookJson()
        {
            string path = Server.MapPath("~/App_Data/workbook.json");

            if (File.Exists(path))
            {
                return File.ReadAllText(path, Encoding.UTF8);
            }

            var workbook = new
            {
                id = "workbook-001",
                name = "銷售報表",
                appVersion = "1.0.0",
                locale = "zhCN",
                styles = new { },
                sheetOrder = new[] { "sheet-1" },
                sheets = new Dictionary<string, object>
                {
                    {
                        "sheet-1",
                        new
                        {
                            id = "sheet-1",
                            name = "Sheet1",
                            rowCount = 20,
                            columnCount = 10,
                            defaultRowHeight = 24,
                            defaultColumnWidth = 100,
                            cellData = new Dictionary<string, object>
                            {
                                {
                                    "0",
                                    new Dictionary<string, object>
                                    {
                                        { "0", new { v = "商品" } },
                                        { "1", new { v = "數量" } },
                                        { "2", new { v = "單價" } },
                                        { "3", new { v = "小計" } }
                                    }
                                },
                                {
                                    "1",
                                    new Dictionary<string, object>
                                    {
                                        { "0", new { v = "蘋果" } },
                                        { "1", new { v = 3 } },
                                        { "2", new { v = 25 } },
                                        { "3", new { v = 75 } }
                                    }
                                },
                                {
                                    "2",
                                    new Dictionary<string, object>
                                    {
                                        { "0", new { v = "香蕉" } },
                                        { "1", new { v = 5 } },
                                        { "2", new { v = 12 } },
                                        { "3", new { v = 60 } }
                                    }
                                }
                            },
                            rowData = new { },
                            columnData = new { },
                            mergeData = new object[] { },
                            showGridlines = 1,
                            rightToLeft = 0,
                            rowHeader = new { width = 46 },
                            columnHeader = new { height = 20 }
                        }
                    }
                }
            };

            return new JavaScriptSerializer().Serialize(workbook);
        }

        [WebMethod]
        public static SaveResult SaveWorkbook(string workbookJson)
        {
            try
            {
                string path = HttpContext.Current.Server.MapPath("~/App_Data/workbook.json");
                string dir = Path.GetDirectoryName(path);

                if (!Directory.Exists(dir))
                {
                    Directory.CreateDirectory(dir);
                }

                File.WriteAllText(path, workbookJson, Encoding.UTF8);

                return new SaveResult
                {
                    success = true,
                    message = "儲存成功：" + DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")
                };
            }
            catch (Exception ex)
            {
                return new SaveResult
                {
                    success = false,
                    message = ex.Message
                };
            }
        }

        public class SaveResult
        {
            public bool success { get; set; }
            public string message { get; set; }
        }
    }
}
