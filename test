import { createUniver, LocaleType, mergeLocales } from 'https://esm.sh/@univerjs/presets@0.20.1';
import { FUniver } from 'https://esm.sh/@univerjs/core@0.20.1/facade';
import { UniverSheetsCorePreset } from 'https://esm.sh/@univerjs/preset-sheets-core@0.20.1';
import zhCN from 'https://esm.sh/@univerjs/preset-sheets-core@0.20.1/locales/zh-CN';
import 'https://esm.sh/@univerjs/sheets@0.20.1/facade';
import 'https://esm.sh/@univerjs/sheets-ui@0.20.1/facade';

const saveButton = document.getElementById('btnSave');
const saveStatus = document.getElementById('saveStatus');

const { univer } = createUniver({
    locale: LocaleType.ZH_CN,
    locales: {
        [LocaleType.ZH_CN]: mergeLocales(zhCN),
    },
    presets: [
        UniverSheetsCorePreset({
            container: 'app',
        }),
    ],
});

const univerAPI = FUniver.newAPI(univer);

console.log('univer =', univer);
console.log('univerAPI =', univerAPI);
console.log('createWorkbook type =', typeof univerAPI.createWorkbook);

if (typeof univerAPI.createWorkbook !== 'function') {
    saveStatus.textContent = '初始化失敗：createWorkbook 不可用';
    throw new Error('univerAPI.createWorkbook is not a function');
}

univerAPI.createWorkbook(window.initialWorkbook);

async function saveWorkbook() {
    try {
        saveButton.disabled = true;
        saveStatus.textContent = '儲存中...';

        const workbook = univerAPI.getActiveWorkbook();
        if (!workbook) {
            throw new Error('找不到 active workbook');
        }

        await workbook.endEditingAsync(true);
        const snapshot = workbook.save();

        const response = await fetch('Default.aspx/SaveWorkbook', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json; charset=utf-8'
            },
            body: JSON.stringify({
                workbookJson: JSON.stringify(snapshot)
            })
        });

        const result = await response.json();

        if (!result.d || !result.d.success) {
            throw new Error((result.d && result.d.message) || '儲存失敗');
        }

        saveStatus.textContent = result.d.message;
    } catch (error) {
        saveStatus.textContent = '儲存失敗：' + error.message;
    } finally {
        saveButton.disabled = false;
    }
}

saveButton.addEventListener('click', saveWorkbook);
